{
  "type": "module",
  "name": "orbitron-tui",
  "version": "1.0.7",
  "description": "A modular TUI backend for Orbitron",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "bin": {
    "orbitron": "bin/orbitron",
    "ob": "bin/orbitron"
  },
  "scripts": {
    "build": "bun build src/main.tsx --outdir dist --target bun && cp bin/orbitron dist/orbitron && chmod +x dist/orbitron",
    "start": "bun run bin/orbitron",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opentui/core": "^0.2.1",
    "@opentui/react": "^0.2.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {},
  "keywords": [
    "tui",
    "backend",
    "modular"
  ],
  "author": "johndih",
  "license": "MIT"
}
